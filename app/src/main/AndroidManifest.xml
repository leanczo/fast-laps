<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.leandro.fastlaps" >

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-feature android:name="android.hardware.type.watch" />
    <uses-permission android:name="com.google.android.wearable.permission.RECEIVE_COMPANION_CONFIGURATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name="com.example.fastlaps.presentation.FastLapsApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@android:style/Theme.DeviceDefault">
        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!--
               Set to true if your app is Standalone, that is, it does not require the handheld
               app to run.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name="com.example.fastlaps.presentation.MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@style/MainActivityTheme.Starting"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="com.example.fastlaps.presentation.complication.NextRaceComplicationService"
            android:exported="true"
            android:icon="@drawable/ic_complication_flag"
            android:label="@string/complication_next_race"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT,LONG_TEXT,MONOCHROMATIC_IMAGE" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="3600" />
        </service>

        <service
            android:name="com.example.fastlaps.presentation.complication.ChampionshipComplicationService"
            android:exported="true"
            android:icon="@drawable/ic_complication_trophy"
            android:label="@string/complication_championship"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT,LONG_TEXT,MONOCHROMATIC_IMAGE" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="3600" />
        </service>

        <service
            android:name="com.example.fastlaps.presentation.complication.DriverComplicationService"
            android:exported="true"
            android:icon="@drawable/ic_complication_driver"
            android:label="@string/complication_driver"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT,LONG_TEXT,MONOCHROMATIC_IMAGE" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="3600" />
        </service>

        <service
            android:name="com.example.fastlaps.presentation.tile.NextRaceTileService"
            android:exported="true"
            android:label="@string/tile_next_race"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/tile_preview_next_race" />
        </service>

        <service
            android:name="com.example.fastlaps.presentation.tile.StandingsTileService"
            android:exported="true"
            android:label="@string/tile_standings"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/tile_preview_standings" />
        </service>
    </application>

</manifest>